{
  "name": "rodeo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "tsc -b && vp build --logLevel error",
    "preview": "vp preview",
    "start": "node .output/server/index.mjs",
    "prepare": "node scripts/setup.mjs",
    "setup": "node scripts/setup.mjs",
    "setup:skills": "vp dlx skills@1.5.15 experimental_install",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "test": "vp test run",
    "test:watch": "vp test watch",
    "test:coverage": "vp test run --coverage",
    "test:e2e": "node scripts/run-playwright.mjs test",
    "test:e2e:ui": "node scripts/run-playwright.mjs test --ui",
    "test:e2e:headed": "node scripts/run-playwright.mjs test --headed",
    "test:e2e:install": "node scripts/run-playwright.mjs install chromium",
    "test:template": "node scripts/test-template.mjs",
    "typecheck": "tsc -b",
    "knip": "knip",
    "check": "node scripts/run-verification.mjs verify:fast",
    "check:push": "node scripts/run-verification.mjs verify:push",
    "check:ci": "node scripts/run-verification.mjs verify:ci",
    "doctor": "react-doctor --verbose"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "calligraph": "^1.4.1",
    "clsx": "^2.1.1",
    "motion": "^12.42.2",
    "penflow": "^0.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.61.1",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-playwright": "^2.10.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "jsdom": "^29.1.1",
    "knip": "^6.25.0",
    "nitro": "^3.0.260610-beta",
    "react-doctor": "0.7.3",
    "typescript": "^6.0.3",
    "vite-plus": "0.2.4",
    "vitest": "4.1.10"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vitest": "4.1.10"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "^11.12.0",
      "onFail": "error"
    },
    "runtime": {
      "name": "node",
      "version": "^24.11.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": "^24.11.0"
  },
  "packageManager": "npm@11.12.0"
}
